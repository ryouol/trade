# Compliance configuration. The risk engine reads this on boot and refuses
# to start if `allowed_venues` is empty or the file is missing.
# Copy to compliance.yaml (gitignored) and adjust before deploying.

# Venues you are legally permitted to trade. Connectors refuse to
# authenticate against any venue not in this list.
allowed_venues:
  - kalshi
  - polymarket_us
  # - polymarket_intl  # international Polygon CLOB; geofenced from US users.
                       # Only enable from a non-US operating jurisdiction.

# Per-strategy starting mode. The risk engine refuses orders for any
# strategy whose mode is `disabled`. Modes can be promoted via
# /api/trading-mode at runtime.
default_strategy_mode: disabled

# Operator self-reported status. If you serve in any covered role (federal
# employee with non-public info on a relevant market, sitting candidate,
# public-company insider on a related market), do not flip these to false
# without explicit legal review.
operator_status:
  is_federal_employee_with_market_info: false
  is_sitting_candidate: false
  is_corporate_insider_on_traded_market: false

# Regex patterns that auto-reject orders. The engine matches against the
# display_title of every market. Add as needed.
banned_markets:
  - "(?i)russia"        # OFAC sanctions surface area
  - "(?i)terror"
  - "(?i)assassin"
  - "(?i)kim jong un"   # avoid jurisdictionally complex contracts

# Hard caps. Risk engine enforces; can only be tightened (not loosened) via
# runtime config. Loosening requires a new compliance.yaml + redeploy.
limits:
  capital_total_usd: 10000        # change after each capital top-up
  max_position_per_market_pct: 5     # of capital
  max_position_per_source_pct: 15    # of capital, grouped by resolution_source
  max_position_per_venue_pct: 60     # of capital
  max_open_orders_per_market: 8

  # Specific to contested-jurisdiction categories
  kalshi_sports_max_position_pct: 2  # state-court risk is unresolved

# Drawdown circuit breakers. Trigger an auto kill-switch.
circuit_breakers:
  daily_drawdown_pct: 4              # 24h realized PnL / capital
  var_99_soft_cap_pct: 15            # auto-deleverage above this
  var_99_hard_cap_pct: 18            # all-stop above this
  uma_dispute_observed: kill_switch  # any active position in disputed market
